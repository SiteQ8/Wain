rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users — authenticated users can read/write own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      
      match /kids/{kidId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Listings — anyone can read, admins can write
    match /listings/{listingId} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'sub_admin', 'owner'];
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth.uid == resource.data.userId;
      }
    }
    
    // Bookings — users see own, admins see all
    match /bookings/{bookingId} {
      allow read: if request.auth.uid == resource.data.userId || 
                     get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'sub_admin', 'owner'];
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId || 
                       get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'sub_admin'];
    }
    
    // Coupons — anyone can read active, admins can write
    match /coupons/{couponId} {
      allow read: if resource.data.active == true;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'sub_admin'];
    }
    
    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin'];
    }
    
    // Admins
    match /admins/{adminId} {
      allow read: if request.auth.uid == adminId;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
